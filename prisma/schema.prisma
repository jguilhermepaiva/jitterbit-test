generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Removido a linha 'url' daqui
}

model Order {
  id           Int      @id @default(autoincrement())
  orderId      String   @unique [cite: 285]
  value        Float    [cite: 286]
  creationDate DateTime [cite: 287]
  items        Item[]
}

model Item {
  id        Int    @id @default(autoincrement())
  productId Int    [cite: 291]
  quantity  Int    [cite: 292]
  price     Float  [cite: 293]
  order     Order  @relation(fields: [orderId], references: [orderId])
  orderId   String [cite: 290]
}