generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabela: Order [cite: 283]
model Order {
  orderId      String   @id // Coluna: orderId [cite: 285]
  value        Float    // Coluna: value [cite: 286]
  creationDate DateTime // Coluna: creationDate [cite: 287]
  items        Items[]
}

// Tabela: Items 
model Items {
  orderId   String // Coluna: orderId [cite: 290]
  productid Int    // Coluna: productid [cite: 291]
  quantity  Int    // Coluna: quantity [cite: 292]
  price     Float  // Coluna: price [cite: 293]

  order     Order  @relation(fields: [orderId], references: [orderId])

  // Define que a combinação destes dois campos é a chave primária
  @@id([orderId, productid]) 
}